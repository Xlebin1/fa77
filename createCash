async function main(){
  // технический метод для остановки времени
  const sleep = async (n) => new Promise((resolve) => setTimeout(resolve, n))

  let counter = 0  // Изменено с const на let, чтобы можно было изменять

  function func(){
      return ++counter
  }
  
  // функция кэширования с временем жизни
  function createCash(fn, ttl) {
      let cachedValue = null;
      let lastCallTime = 0;
      
      return function() {
          const currentTime = Date.now();
          
          // Если кэш пуст или время жизни истекло
          if (cachedValue === null || currentTime - lastCallTime > ttl) {
              cachedValue = fn(); // вызываем оригинальную функцию
              lastCallTime = currentTime; // обновляем время последнего вызова
          }
          
          return cachedValue;
      };
  }

  // пример использования
  const myCash = createCash(func, 1000) // функция принимает на вход функцию для вызова, и время через которое значение становится неактуальным

  await sleep(1000)
  console.log(myCash()) // 1
  console.log(myCash()) // 1

  await sleep(3000)
  console.log(myCash()) // 2
  console.log(myCash()) // 2
}

main()
